---
const milestones = [
  {
    title: "Topic Assessment",
    date: "Milestone 1",
    status: "Completed",
    description: "Initial problem definition and research direction validation."
  },
  {
    title: "Proposal Presentation",
    date: "Milestone 2",
    status: "Completed",
    description: "Presented project scope, motivation, and planned solution approach."
  },
  {
    title: "Progress Presentation 1",
    date: "Milestone 3",
    status: "Completed",
    description: "Reviewed early design, architecture, and component direction."
  },
  {
    title: "Progress Presentation 2",
    date: "Milestone 4",
    status: "Completed",
    description: "Showcased implementation progress and component-level validation."
  },
  {
    title: "Research Paper",
    date: "Milestone 5",
    status: "Ongoing",
    description: "Prepared technical research writing and publication-oriented documentation."
  },
  {
    title: "Final Report",
    date: "Milestone 6",
    status: "Ongoing",
    description: "Compiling the full project documentation and implementation details."
  },
  {
    title: "Final Presentation / Viva",
    date: "Milestone 7",
    status: "Upcoming",
    description: "Final project defense and research outcome demonstration."
  }
];
---

<section id="milestones" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-sm uppercase tracking-[0.2em] text-sky-200">Project Milestones</p>
      <h2 class="text-3xl md:text-4xl font-bold font-heading text-white mt-3">
        Project Milestones
      </h2>
      <p class="text-slate-400 mt-4 max-w-2xl mx-auto">
        Concise timeline of research milestones and academic checkpoints.
      </p>
    </div>

    <div class="relative">
      <div class="absolute left-4 md:left-1/2 top-0 h-full w-px bg-white/10 md:-translate-x-1/2"></div>
      <div class="space-y-10">
        {milestones.map((item, index) => (
          <div class={`relative flex flex-col md:flex-row ${index % 2 === 0 ? 'md:justify-start' : 'md:justify-end'} items-start md:items-center gap-6`}>
            <div class={`w-full md:w-[44%] ${index % 2 === 0 ? 'md:pr-8' : 'md:pl-8'}`}>
              <div class="glass-soft card-hover rounded-2xl p-6 border border-white/10 reveal">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                  <span class="text-xs px-2 py-1 rounded-full bg-white/10 text-slate-200 border border-white/10">{item.date}</span>
                </div>
                <p class="text-sm text-slate-400 leading-relaxed mb-4">{item.description}</p>
                <div class="flex items-center gap-3 text-xs">
                  <span class="px-2.5 py-1 rounded-full bg-sky-500/15 text-sky-200 border border-sky-400/30">{item.status}</span>
                </div>
              </div>
            </div>
            <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-sky-400 shadow-[0_0_20px_rgba(56,189,248,0.7)] md:-translate-x-1/2"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
